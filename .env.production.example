# ────────────────────────────────────────────────────────────────────────────────
# 生产环境配置模板
# 复制此文件为 .env.production 并填入真实值
# ────────────────────────────────────────────────────────────────────────────────

# 数据库连接 - 必填
# 格式: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://username:password@your-host:5432/hcy_website"

# 管理后台密码 - 必填（请使用强密码）
ADMIN_PASSWORD="CHANGE_THIS_PASSWORD_IN_PRODUCTION"

# 网站访问地址 - 必填
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# 图片 CDN 域名 - 必填
NEXT_PUBLIC_IMAGE_BASE_URL="https://image.website.aieducenter.com"

# 腾讯云 COS 配置 - 图片上传功能必填
# 获取地址: https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID="your-secret-id"
COS_SECRET_KEY="your-secret-key"
COS_BUCKET="hcy-website-1415442236"
COS_REGION="ap-beijing"

NODE_ENV=production
