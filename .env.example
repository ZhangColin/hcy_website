# ────────────────────────────────────────────────────────────────────────────────
# 环境变量配置示例
# 复制此文件为 .env.development 或 .env.production 并填写实际值
# ────────────────────────────────────────────────────────────────────────────────

# 数据库连接 (PostgreSQL)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://username:password@localhost:5432/hcy_website"

# 管理后台认证
ADMIN_PASSWORD="your-secure-password-here"

# 应用配置
NODE_ENV="production"

# 站点配置 (可选，用于覆盖默认值)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# 腾讯云 COS 配置
COS_SECRET_ID=your_secret_id_here
COS_SECRET_KEY=your_secret_key_here
COS_BUCKET=hcy-website-1415442236
COS_REGION=ap-beijing

# 图片基础 URL (前端使用)
NEXT_PUBLIC_IMAGE_BASE_URL=https://image.website.aieducenter.com

# 旧数据库连接（用于新闻数据迁移，临时使用，迁移完成后可删除）
OLD_DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
